#!/bin/sh

set -e

echo "Running pre-commit hooks..."

# 1. Format
echo "Running code formatting..."
mvn spotless:apply
mvn spotless:check

# 2. Build
echo "Building..."
make build

# 3. Test
echo "Running tests..."
make test

# 4. Lint
echo "Running linters..."
mvn checkstyle:check

# 5. Build WASM
echo "Checking build_wasm..."
make build_wasm

# 6. Update Badges
echo "Updating badges..."
python3 scripts/update_badges.py

# 7. Swagger 2.0 Petstore Test
echo "Running Swagger 2.0 Petstore test generation and compile..."
rm -rf ../cdd-java-client-v2
java -cp "lib/*:bin" cli.Main from_openapi to_sdk -i "../petstore.json" --tests -o "../cdd-java-client-v2"
(cd ../cdd-java-client-v2 && mvn clean test-compile)

# 8. OpenAPI 3.2.0 Petstore Test
echo "Running OpenAPI 3.2.0 Petstore test generation and compile..."
rm -rf ../cdd-java-client-v3
java -cp "lib/*:bin" cli.Main from_openapi to_sdk -i "../petstore_oas3.json" --tests -o "../cdd-java-client-v3"
(cd ../cdd-java-client-v3 && mvn clean test-compile)

# Add README.md, Makefile and formatting changes back to the commit
git add README.md src/ pom.xml scripts/update_badges.py Makefile

echo "Pre-commit hooks passed!"
exit 0
