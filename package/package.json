{
  "name": "cdd-java-cli",
  "version": "0.0.3",
  "description": "JS Wrapper for cdd-java WASM module",
  "main": "dist/index.js",
  "browser": "dist/browser.js",
  "exports": {
    ".": {
      "node": "./dist/index.js",
      "import": "./dist/browser.js",
      "require": "./dist/index.js",
      "default": "./dist/browser.js"
    },
    "./cdd-java.js": "./dist/cdd-java.js",
    "./cdd-java.js.wasm": "./dist/cdd-java.js.wasm"
  },
  "scripts": {
    "build": "mkdir -p dist && cp src/index.js dist/index.js && cp src/browser.js dist/browser.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {},
  "devDependencies": {}
}
